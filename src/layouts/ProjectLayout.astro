---
import { type ProjectSchema } from "../content/config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";

export interface Props extends ProjectSchema {}

const {
  title,
  description,
  pubDate,
  heroImage,
  badge,
  category,
  institution,
  supervisor,
  url,
  tags = [],
} = Astro.props;
dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("MMM YYYY");
---

<BaseLayout title={title} description={description} image={heroImage} ogType="article">
  <main class="md:flex md:justify-center">
    <article class="prose prose-lg max-w-[750px] prose-img:mx-auto">
      {heroImage && (
        <img src={heroImage} alt={title} class="w-full mb-6 rounded-lg" />
      )}
      <h1 class="title my-2 text-4xl font-bold">{title}</h1>

      <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm opacity-70 my-3">
        {pubDate && <time>{displayDate}</time>}
        {category && <span>· {category}</span>}
        {institution && <span>· {institution}</span>}
      </div>

      {badge && <div class="badge badge-secondary my-1">{badge}</div>}
      {
        tags &&
          tags.map((tag) => (
            <span class="badge badge-outline ml-2 no-underline">{tag}</span>
          ))
      }

      {supervisor && (
        <p class="text-sm opacity-80 mt-2"><strong>Supervisor:</strong> {supervisor}</p>
      )}
      {url && (
        <p class="text-sm mt-1">
          <a href={url} target="_blank" rel="noopener">External link ↗</a>
        </p>
      )}

      <div class="divider my-2"></div>
      <slot />
    </article>
  </main>
</BaseLayout>
