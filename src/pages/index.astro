---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const last_projects = projects.slice(0, 2);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-5 mt-5">
    <div class="text-base opacity-50 tracking-widest uppercase mb-2">Hello</div>
    <div class="text-5xl font-bold leading-tight tracking-tight">I'm Hooshmand Rahmani</div>
    <div class="text-xl mt-3 opacity-60 font-medium">
      PhD Candidate · Quantitative Analyst · Operations Researcher
    </div>
    <div class="mt-6 space-y-3">
      <p class="text-lg leading-relaxed">
        I'm a PhD researcher in Business Analytics and Operations Management at
        <b>Sabanci University</b>, with a background in industrial engineering. My work focuses
        on mathematical modelling and data-driven decision systems — translating complex,
        uncertain operational problems into rigorous models that support better decisions.
      </p>
      <p class="text-lg leading-relaxed">
        My research spans robust optimization, stochastic modelling, integer programming, and
        machine learning, with applications in healthcare operations, sustainable supply
        chains, and remanufacturing systems. I also teach and support over 250 MBA and
        undergraduate students at Sabanci Business School.
      </p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a class="btn btn-neutral px-6" href="/projects">Projects</a>
      <a class="btn btn-outline px-6" href="/cv">View CV</a>
      <a class="btn btn-outline px-6" href="/contact">Contact</a>
    </div>
  </div>

  <div class="divider my-2"></div>

  <div class="mb-5 p-5 rounded-2xl bg-base-200 border border-base-300/60">
    <div class="text-xs uppercase tracking-widest opacity-40 mb-1">Current Focus</div>
    <p class="text-base leading-relaxed">
      Robust optimization and stochastic modelling for sustainable supply chains and healthcare operations.
    </p>
  </div>

  <div class="mb-4 flex items-center justify-between">
    <div class="text-2xl font-bold">Recent projects</div>
    <a href="/projects" class="btn btn-sm btn-ghost">All projects →</a>
  </div>

  {
    last_projects.map((project) => (
      <>
        <HorizontalCard
          title={project.data.title}
          titlePrefix={project.data.titlePrefix}
          img={project.data.heroImage}
          desc={project.data.description}
          url={"/projects/" + createSlug(project.data.title, project.slug)}
          target="_self"
          badge={project.data.badge}
          tags={project.data.tags}
        />
        <div class="divider my-0" />
      </>
    ))
  }

  <div class="divider my-2"></div>

  <blockquote class="my-4 px-8 border-l-2 border-base-300">
    <p class="italic opacity-50 text-lg leading-relaxed">
      "Exploring the unknown requires tolerating uncertainty."
    </p>
    <footer class="mt-2 text-sm opacity-40 not-italic">— Brian Greene</footer>
  </blockquote>
</BaseLayout>
