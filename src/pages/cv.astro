    </div>
  </div>

  <!-- Languages -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Languages</div>
  </div>
  <div class="mb-10 grid md:grid-cols-2 gap-3">
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between bg-base-200 rounded-xl px-4 py-3">
        <span>English</span>
        <span class="badge badge-neutral">Native or Bilingual</span>
