    </li>
    <li>
      <strong>Mir Saman Pishvaee, PhD</strong> — Professor<br />
      Iran University of Science and Technology · School of Industrial Engineering<br />
      <span class="text-sm opacity-80">pishvaee@iust.ac.ir</span>
    </li>
    <li>
      <strong>Morteza Ghomi-Avili, PhD</strong> — Graduate Research Assistant<br />
      Sharif University of Technology · School of Industrial Engineering<br />
      <span class="text-sm opacity-80">morteza.ghomi@sharif.edu</span>
    </li>
  </ul>
</BaseLayout>
