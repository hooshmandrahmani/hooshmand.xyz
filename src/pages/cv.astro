      location="Istanbul, Türkiye"
    >
      <div class="flex flex-wrap gap-2 mb-3">
        <span class="text-xs px-2.5 py-1 rounded-lg bg-base-200 border border-base-300">300+ students · MBA & Undergraduate</span>
      </div>
      <ul class="grid gap-1">
        <li class="flex items-start justify-between gap-4"><span>MKTG 560 — Applications in Digital Marketing (15 MBA)</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Jan — Jun 2026</span></li>
        <li class="flex items-start justify-between gap-4"><span>BAN 801 — Marketing Analytics (14 MBA)</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Jan — Jun 2026</span></li>
        <li class="flex items-start justify-between gap-4"><span>MGMT 201 — Introduction to Management (110 undergraduates)</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Sep 2025 — Jan 2026</span></li>
        <li class="flex items-start justify-between gap-4"><span>MGMT 402 — Entrepreneurship (40 undergraduates)</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Jan — Jun 2025</span></li>
        <li class="flex items-start justify-between gap-4"><span>MGMT 201 — Introduction to Management (70 undergraduates)</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Jan — Jun 2025</span></li>
        <li class="flex items-start justify-between gap-4"><span>OPIM 501 — Operations & Supply Chain Management (30 MBA)</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Sep 2024 — Jan 2025</span></li>
        <li class="flex items-start justify-between gap-4"><span>OPIM 390 — Introduction to Business Analytics (25 undergraduates)</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Sep 2024 — Jan 2025</span></li>
      </ul>
    </TimeLineElement>
    <TimeLineElement
      title="Graduate Teaching Assistant"
      institution="School of Industrial Engineering, Iran University of Science and Technology"
      date="Jan 2019 — Jun 2024"
      location="Tehran, Iran"
    >
      <div class="flex flex-wrap gap-2 mb-3">
        <span class="text-xs px-2.5 py-1 rounded-lg bg-base-200 border border-base-300">70+ students</span>
      </div>
      <ul class="grid gap-1">
        <li class="flex items-start justify-between gap-4"><span>Graduate thesis advising</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Oct 2021 — Jun 2024</span></li>
        <li class="flex items-start justify-between gap-4"><span>IE 201 — Engineering Economics (37 undergraduates)</span><span class="text-xs opacity-50 shrink-0 whitespace-nowrap mt-0.5">Jan — Jun 2019</span></li>
      </ul>
    </TimeLineElement>
  </div>

  <!-- Skills -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>
  <div class="grid md:grid-cols-2 gap-x-8 gap-y-6 mb-10">
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Research Methods</div>
      <p class="text-sm opacity-80">Robust Optimization · Stochastic Programming · Integer Programming · Data-driven Optimization · Machine Learning · Experimental Design · Structural Equation Modeling</p>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Programming</div>
      <p class="text-sm opacity-80">Python · R · MATLAB · Stata · Git</p>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Optimization Solvers</div>
      <p class="text-sm opacity-80">Gurobi · GAMS · CPLEX</p>
    </div>
    <div>
