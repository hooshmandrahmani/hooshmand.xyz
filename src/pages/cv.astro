---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="CV" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Curriculum Vitae</div>
    <p class="py-2 opacity-80">
      A complete record of my education, research, publications, teaching, awards, and
      technical skills.
    </p>
  </div>

  <div class="divider my-2"></div>

  <!-- Profile -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>
  <div class="mb-10 text-justify">
    I'm a PhD researcher in Business Analytics and Operations Management at Sabanci
    University, with a background in industrial engineering. My work focuses on
    mathematical modelling and data-driven decision systems. My research spans robust
    optimization, stochastic modelling, integer programming, and machine learning, with
    applications in healthcare operations, sustainable supply chains, and remanufacturing
    systems.
  </div>

  <!-- Education -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>
  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="PhD — Business Analytics & Operations Management"
      subtitle="Sep 2024 — Present · Sabanci Business School, Sabanci University · Istanbul, Türkiye · GPA 3.5 / 4.00 · Full Scholarship"
    >
      <strong>Coursework:</strong> Modelling in Operations Management · Stochastic
      Processes · Data Mining · Operations and Decision Analytics · Empirical Methods in
      Operations Management · Data and AI Ethics · Philosophy of Science and Society ·
      Judgment and Decision Making · Probability and Statistics · Operations Research.
    </TimeLineElement>
    <TimeLineElement
      title="MSc — Industrial Engineering"
      subtitle="Sep 2018 — Sep 2021 · Iran University of Science and Technology · Tehran, Iran · GPA 18.33 / 20.00 · Fellowship recipient"
    >
      <strong>Thesis:</strong> Multi-objective robust optimization model for
      remanufacturing under uncertain quality and time. Supervisor: Dr. Ahmad Makui.<br />
      <strong>Coursework:</strong> Game Theory · Econometrics · Operations Research ·
      Uncertain Programming (Robust Optimization) · Fuzzy Theory and Applications · Network
      Theory · Systems Engineering · Computer Simulation and Optimization.
    </TimeLineElement>
    <TimeLineElement
      title="BSc — Engineering"
      subtitle="Sep 2013 — Sep 2017 · Amirkabir University of Technology · Tehran, Iran · Fellowship recipient · Top 2% in Iran's University Entrance Exam"
    >
      <strong>Thesis:</strong> Statistical risk assessment in mines. Supervisor: Dr. Kourosh
      Shahriar.
    </TimeLineElement>
  </div>

  <!-- Working Papers -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Working Papers</div>
  </div>
  <ul class="list-disc mx-6 mb-10 grid gap-3">
    <li>
      <strong
        >Multi-objective robust optimization model for hybrid manufacturing and
        remanufacturing planning under uncertainty.</strong
      >
      <div class="text-sm opacity-70">
        H. Rahmani, A. Makui — <em>Working paper · In progress</em>
      </div>
    </li>
    <li>
      <strong
        >Green closed-loop supply chain model for remanufacturing to reduce waste and its
        environmental impacts with Robust Fuzzy Stochastic Programming.</strong
      >
      <div class="text-sm opacity-70">
        H. Rahmani, A. Makui — <em>Working paper · In progress</em>
      </div>
    </li>
  </ul>

  <!-- Research Experience -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Research Experience</div>
  </div>

  <div class="text-xl font-semibold mb-3 mt-2 opacity-80">Sabanci University</div>
  <div class="time-line-container grid gap-4 mb-8">
    <TimeLineElement
      title="Robust Optimization for Integrated Healthcare Scheduling"
      subtitle="Jan 2026 · Sabanci Business School · Supervisor: Dr. Burak Gokgur"
    >
      Formulated an MILP model with budgeted uncertainty in Python (Gurobi) to co-optimize
      surgical planning and nurse assignment, preventing staff workload violations during
      stochastic demand spikes.
    </TimeLineElement>
    <TimeLineElement
      title="The Integrated Healthcare Timetabling Problem — A Review of Optimization Models and Solution Methods"
      subtitle="Oct 2025 · Sabanci Business School · PhD Summer Paper · Supervisor: Dr. Can Akkan"
    >
      Literature review synthesizing foundational metaheuristics and optimization models
      for integrated, dynamic hospital scheduling.
    </TimeLineElement>
    <TimeLineElement
      title="Next-Basket Prediction using Bidirectional Transformers with Data Augmentation"
      subtitle="Jun 2025 · Sabanci Business School · Supervisor: Dr. Yucel Saygin"
    >
      Improved an e-commerce recommendation system by applying a bidirectional Transformer
      and data augmentation to better capture customer shopping patterns and predict next
      purchases.
    </TimeLineElement>
    <TimeLineElement
      title="An Empirical Study on Consumer Trust and Willingness-to-Pay"
      subtitle="Jun 2025 · Sabanci Business School · Supervisor: Dr. Melek Akın Ateş"
    >
      Designed an empirical study using Structural Equation Modeling to analyze green
      trust's mediating role in sustainable technology purchasing behavior.
    </TimeLineElement>
    <TimeLineElement
      title="Customer Lifetime Value Assessment via K-Means Clustering"
      subtitle="Jan 2025 · Sabanci Business School · Supervisor: Dr. Kemal Kılıç"
    >
      Combined traditional RFM modeling with weighted K-Means clustering to predict
      customer lifetime value across e-commerce segments.
    </TimeLineElement>
  </div>

  <div class="text-xl font-semibold mb-3 opacity-80">Iran University of Science and Technology</div>
  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="MSc Thesis — Multi-objective Robust Optimization for Remanufacturing"
      subtitle="Sep 2021 · School of Industrial Engineering · Supervisor: Dr. Ahmad Makui"
    >
      Developed a multi-objective optimization model for hybrid manufacturing and
      remanufacturing planning under uncertainty. Modeled uncertainty in the quality and
      quantity of returned products, production times, and demand to enhance strategic
      planning in closed-loop supply chains.
    </TimeLineElement>
    <TimeLineElement
      title="Conceptual and Mathematical Modeling in Remanufacturing Systems"
      subtitle="Oct 2020 · School of Industrial Engineering · Supervisor: Dr. Ahmad Makui"
    >
      Conducted an extensive literature review evaluating analytical modeling approaches to
      optimize recovery, reuse, and production planning within remanufacturing environments.
    </TimeLineElement>
    <TimeLineElement
      title="Blockchain-Based Verification Frameworks for Supply Chain Transparency"
      subtitle="Jan 2023 · School of Industrial Engineering · Supervisor: Dr. Morteza Ghomi-Avili"
    >
      Evaluated blockchain frameworks to enhance supply chain transparency, utilizing
      decentralized digital records to ensure product originality and streamline partner
      verification.
    </TimeLineElement>
    <TimeLineElement
      title="Large-Scale Optimization of Healthcare Logistics via Benders Decomposition"
      subtitle="Dec 2019 · School of Industrial Engineering · Supervisor: Dr. Hadi Sahebi"
    >
      Implemented a Benders decomposition algorithm in GAMS to efficiently solve a complex
      optimization model for blood supply chain distribution.
    </TimeLineElement>
    <TimeLineElement
      title="Review of Data-Driven Robust Optimization Methodologies"
      subtitle="Dec 2019 · School of Industrial Engineering · Supervisor: Dr. Mir Saman Pishvaee"
    >
      Evaluated major data-driven robust optimization frameworks, analyzing methodologies
      for integrating empirical data into uncertainty sets for complex decision-making
      environments.
    </TimeLineElement>
    <TimeLineElement
      title="Analytical Approaches in Multi-Modal Transportation Systems"
      subtitle="Jun 2019 · School of Industrial Engineering · Supervisor: Dr. Mahdi Hosseini-Motlagh"
    >
      Reviewed analytical and optimization approaches for multi-modal transportation,
      assessing their strategic relevance in complex logistics and transportation planning.
    </TimeLineElement>
    <TimeLineElement
      title="Discrete-Event Queueing Simulation for Transportation Systems"
      subtitle="Jan 2019 · School of Industrial Engineering · Supervisor: Dr. Kamran Shahanaghi"
    >
      Developed an Arena simulation model to evaluate system-wide transportation
      performance, analyze queue dynamics, and identify operational bottlenecks.
    </TimeLineElement>
  </div>

  <!-- Teaching -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Teaching Experience</div>
  </div>
  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Graduate Teaching Assistant — Sabanci Business School"
      subtitle="Sep 2024 — Present · Sabanci University · Over 250 students"
    >
      <ul class="list-disc ml-5">
        <li>MKTG 560 — Applications in Digital Marketing (MBA) · Jan — Jun 2026</li>
        <li>BAN 801 — Marketing Analytics (MBA) · Jan — Jun 2026</li>
        <li>MGMT 201 — Introduction to Management (110 undergrads) · Sep 2025 — Jan 2026</li>
        <li>MGMT 402 — Entrepreneurship (30 undergrads) · Jan — Jun 2025</li>
        <li>MGMT 201 — Introduction to Management (52 undergrads) · Jan — Jun 2025</li>
        <li>OPIM 501 — Operations & Supply Chain Management (27 MBA) · Sep 2024 — Jan 2025</li>
        <li>OPIM 390 — Introduction to Business Analytics (21 undergrads) · Sep 2024 — Jan 2025</li>
      </ul>
    </TimeLineElement>
    <TimeLineElement
      title="Graduate Teaching Assistant — School of Industrial Engineering"
      subtitle="Jan 2019 — Jun 2024 · Iran University of Science and Technology · Over 70 students"
    >
      <ul class="list-disc ml-5">
        <li>Research — Thesis advising for graduate students · Oct 2021 — Jun 2024</li>
        <li>IE 201 — Engineering Economics (37 undergrads) · Jan — Jun 2019</li>
      </ul>
    </TimeLineElement>
  </div>

  <!-- Skills -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>
  <div class="grid md:grid-cols-2 gap-x-8 gap-y-6 mb-10">
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Methodology</div>
      <div class="flex flex-wrap gap-2">
        <span class="text-sm opacity-80">Robust Optimization</span>
        <span class="text-sm opacity-80">Stochastic Modelling</span>
        <span class="text-sm opacity-80">Data-driven Optimization</span>
        <span class="text-sm opacity-80">Integer Programming</span>
        <span class="text-sm opacity-80">Machine Learning</span>
        <span class="text-sm opacity-80">Experimental Design</span>
        <span class="text-sm opacity-80">Empirical Methods</span>
      </div>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Programming</div>
      <div class="flex flex-wrap gap-2">
        <span class="text-sm opacity-80">Python</span>
        <span class="text-sm opacity-80">R</span>
        <span class="text-sm opacity-80">Git</span>
        <span class="text-sm opacity-80">MATLAB</span>
        <span class="text-sm opacity-80">Stata</span>
      </div>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Optimization Tools</div>
      <div class="flex flex-wrap gap-2">
        <span class="text-sm opacity-80">Gurobi</span>
        <span class="text-sm opacity-80">GAMS</span>
        <span class="text-sm opacity-80">CPLEX</span>
      </div>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Analytics & Engineering</div>
      <div class="flex flex-wrap gap-2">
        <span class="text-sm opacity-80">Minitab</span>
        <span class="text-sm opacity-80">Vensim</span>
        <span class="text-sm opacity-80">SmartPLS</span>
        <span class="text-sm opacity-80">Arena</span>
        <span class="text-sm opacity-80">EViews</span>
        <span class="text-sm opacity-80">@Risk</span>
        <span class="text-sm opacity-80">Bizagi</span>
        <span class="text-sm opacity-80">Best Fit</span>
      </div>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Automation</div>
      <div class="flex flex-wrap gap-2">
        <span class="text-sm opacity-80">N8N</span>
        <span class="text-sm opacity-80">API Integration</span>
      </div>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">AI-Based Development</div>
      <div class="flex flex-wrap gap-2">
        <span class="text-sm opacity-80">Claude Code</span>
        <span class="text-sm opacity-80">Codex</span>
        <span class="text-sm opacity-80">Opencode</span>
      </div>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Reporting</div>
      <div class="flex flex-wrap gap-2">
        <span class="text-sm opacity-80">LaTeX</span>
        <span class="text-sm opacity-80">Microsoft Office</span>
      </div>
    </div>
  </div>

  <!-- Test scores -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Test Scores</div>
  </div>
  <div class="flex gap-4 mb-10 text-center">
    <div class="flex-1 bg-base-200 rounded-xl py-6 px-4">
      <div class="text-4xl font-bold">105</div>
      <div class="font-medium mt-1">TOEFL iBT</div>
      <div class="text-sm opacity-50 mt-1">R 28 · L 28 · S 25 · W 24<br/>Aug 2024</div>
    </div>
    <div class="flex-1 bg-base-200 rounded-xl py-6 px-4">
      <div class="text-4xl font-bold">311</div>
      <div class="font-medium mt-1">GRE General</div>
      <div class="text-sm opacity-50 mt-1">Q 167 · V 144 · AW 3.0<br/>Nov 2022</div>
    </div>
  </div>

  <!-- Languages -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Languages</div>
  </div>
  <div class="mb-10 grid md:grid-cols-2 gap-3">
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between bg-base-200 rounded-xl px-4 py-3">
        <span>English</span>
        <span class="badge badge-neutral">Native or Bilingual</span>
      </div>
      <div class="flex items-center justify-between bg-base-200 rounded-xl px-4 py-3">
        <span>Persian</span>
        <span class="badge badge-neutral">Native or Bilingual</span>
      </div>
