    <li>Amirkabir University of Technology Fellowship, bachelor's degree — Sep 2013</li>
    <li>Top 2% among 252,000 in Iran's University Entrance Exam — Aug 2013</li>
  </ul>

  <!-- Hobbies -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Hobbies & Interests</div>
  </div>
  <div class="mb-10 opacity-80">
    Tennis · Running · Photography · Kamancheh · Tar · Setar
  </div>

  <!-- References -->
  <div class="mb-5">
