      </div>
    </div>
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between bg-base-200 rounded-xl px-4 py-3.5">
        <span class="font-medium">Kurdish</span>
        <div class="w-48 shrink-0">
          <span class="w-full block text-sm font-medium rounded-full px-3 py-1 bg-neutral text-neutral-content text-center">Native or Bilingual</span>
        </div>
      </div>
      <div class="flex items-center justify-between bg-base-200 rounded-xl px-4 py-3.5">
        <span class="font-medium">Turkish</span>
        <div class="w-48 shrink-0 flex flex-col gap-1.5">
          <span class="w-full block text-xs font-medium rounded-full px-3 py-1 border border-base-content/25 text-base-content/75 text-center">Basic · Actively Learning</span>
          <a href="https://www.duolingo.com/profile/hooshmand" target="_blank"
            id="duolingo-tr"
            class="w-full block text-xs font-semibold text-white rounded-full px-3 py-1 text-center transition-opacity duration-150 hover:opacity-90"
            style="background-color:#58CC02;">Duolingo score 11 ↗</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    async function updateDuolingoScores() {
      try {
        const res = await fetch(
          'https://www.duolingo.com/2017-06-30/users?username=hooshmand&fields=courses',
          { headers: { 'Accept': 'application/json' } }
        );
        if (!res.ok) return;
        const data = await res.json();
        const courses = data.users?.[0]?.courses ?? [];
        const it = courses.find((c: any) => c.learningLanguage === 'it');
        const tr = courses.find((c: any) => c.learningLanguage === 'tr');
        const elIt = document.getElementById('duolingo-it');
        const elTr = document.getElementById('duolingo-tr');
        if (it && elIt) elIt.textContent = `Duolingo score ${it.xp} ↗`;
        if (tr && elTr) elTr.textContent = `Duolingo score ${tr.xp} ↗`;
      } catch {
        // silently keep the hardcoded fallback values
      }
    }
    document.addEventListener('astro:page-load', updateDuolingoScores);
  </script>

  <!-- Honors & Awards -->
