      <p class="text-sm opacity-80">Arena · SmartPLS · @Risk · Minitab · Vensim · EViews · Best Fit</p>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest opacity-50 mb-2">Scientific Writing</div>
