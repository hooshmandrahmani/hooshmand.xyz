---
import { type CollectionEntry, getCollection } from "astro:content";
import { type ProjectSchema } from "../../content/config";
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import createSlug from "../../lib/createSlug";

export async function getStaticPaths() {
  const entries = (await getCollection("projects")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return entries.map((entry, i) => {
    const prev = i > 0 ? entries[i - 1] : null;
    const next = i < entries.length - 1 ? entries[i + 1] : null;
    return {
      params: { slug: createSlug(entry.data.title, entry.slug) },
      props: {
        entry,
        prev: prev && {
          title: prev.data.title,
          url: "/projects/" + createSlug(prev.data.title, prev.slug),
        },
        next: next && {
          title: next.data.title,
          url: "/projects/" + createSlug(next.data.title, next.slug),
        },
      },
    };
  });
}

interface ProjectLink {
  title: string;
  url: string;
}

interface Props {
  entry: CollectionEntry<"projects">;
  prev: ProjectLink | null;
  next: ProjectLink | null;
}

const { entry, prev, next } = Astro.props;
const project: ProjectSchema = entry.data;
const { Content } = await entry.render();
---

<ProjectLayout
  title={project.title}
  description={project.description}
  pubDate={project.pubDate}
  heroImage={project.heroImage}
  badge={project.badge}
  category={project.category}
  institution={project.institution}
  supervisor={project.supervisor}
  url={project.url}
  tags={project.tags}
>
  <Content />

  <div class="divider mt-10 mb-4"></div>
  <nav class="grid sm:grid-cols-2 gap-3 not-prose" aria-label="Project navigation">
    {prev ? (
      <a href={prev.url} class="block rounded-xl border border-base-300 hover-green-border hover:shadow-md transition-all duration-200 p-4">
        <div class="text-xs uppercase tracking-widest opacity-50 mb-1">← Newer project</div>
        <div class="font-semibold text-sm leading-snug">{prev.title}</div>
      </a>
    ) : <span class="hidden sm:block"></span>}
    {next && (
      <a href={next.url} class="block rounded-xl border border-base-300 hover-green-border hover:shadow-md transition-all duration-200 p-4 sm:text-right">
        <div class="text-xs uppercase tracking-widest opacity-50 mb-1">Older project →</div>
        <div class="font-semibold text-sm leading-snug">{next.title}</div>
      </a>
    )}
  </nav>
</ProjectLayout>
