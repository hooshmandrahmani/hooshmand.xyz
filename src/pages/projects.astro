---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [
  { label: "Optimization & Uncertainty Modelling", slug: "optimization-uncertainty" },
  { label: "Machine Learning", slug: "machine-learning" },
  { label: "Empirical Research", slug: "empirical-research" },
];
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Research Experience & Projects</div>
    <p class="py-2 opacity-80">
      Selected research, optimization, and analytics work.
    </p>
    <div class="flex flex-wrap gap-2 mt-3">
      {categories.map((c) => (
        <a href={`#${c.slug}`} class="btn btn-sm btn-outline">{c.label}</a>
      ))}
    </div>
  </div>

  <div class="divider my-2"></div>

  {categories.map((cat) => {
    const catProjects = projects.filter((p) => p.data.category === cat.label);
    if (catProjects.length === 0) return null;
    return (
      <>
        <div id={cat.slug} class="text-2xl font-bold mt-8 mb-3 scroll-mt-6">
          {cat.label}
        </div>
        {catProjects.map((project) => (
          <>
            <HorizontalCard
              title={project.data.title}
              titlePrefix={project.data.titlePrefix}
              img={project.data.heroImage}
              desc={project.data.description}
              url={"/projects/" + createSlug(project.data.title, project.slug)}
              target="_self"
              badge={project.data.badge}
              tags={project.data.tags}
            />
            <div class="divider divider-green my-0" />
          </>
        ))}
      </>
    );
  })}
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    // Scroll to hash on arrival (e.g. navigating from homepage via View Transitions)
    if (window.location.hash) {
      const el = document.getElementById(window.location.hash.slice(1));
      if (el) el.scrollIntoView({ behavior: "smooth" });
    }

    // Intercept sidebar category clicks only when already on this page
    document.querySelectorAll('a[href^="/projects#"]').forEach((link) => {
      link.addEventListener("click", (e) => {
        if (window.location.pathname !== "/projects") return;
        e.preventDefault();
        const id = (link.getAttribute("href") as string).split("#")[1];
        document.getElementById(id)?.scrollIntoView({ behavior: "smooth" });
      });
    });
  });
</script>
