---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Contact</div>
    <p class="py-2 opacity-80">
      Feel free to reach out through any of the channels below.
    </p>
  </div>

  <div class="divider my-2"></div>

  <div class="grid gap-3 mt-6">

    <a href="mailto:hooshmand.rahmani@gmail.com"
      class="group flex items-center gap-5 p-5 rounded-2xl border border-base-300 hover-green-border hover:bg-base-200 hover:shadow-md hover:-translate-y-[2px] transition-all duration-200">
      <div class="w-11 h-11 rounded-xl bg-base-200 group-hover:bg-base-300 group-hover:text-site-green flex items-center justify-center shrink-0 transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="M3 7l9 6 9-6"></path>
        </svg>
      </div>
      <div class="grow">
        <div class="font-semibold">Email</div>
        <div class="text-sm opacity-50 mt-0.5">hooshmand.rahmani@gmail.com</div>
      </div>
      <span class="opacity-30 group-hover:opacity-70 group-hover:translate-x-1 transition-all duration-200 text-lg">→</span>
    </a>

    <a href="https://github.com/hooshmandrahmani" target="_blank" rel="noopener"
      class="group flex items-center gap-5 p-5 rounded-2xl border border-base-300 hover-green-border hover:bg-base-200 hover:shadow-md hover:-translate-y-[2px] transition-all duration-200">
      <div class="w-11 h-11 rounded-xl bg-base-200 group-hover:bg-base-300 group-hover:text-site-green flex items-center justify-center shrink-0 transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" class="opacity-70" style="fill: currentColor;">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </div>
      <div class="grow">
        <div class="font-semibold">GitHub</div>
        <div class="text-sm opacity-50 mt-0.5">github.com/hooshmandrahmani</div>
      </div>
      <span class="opacity-30 group-hover:opacity-70 group-hover:translate-x-1 transition-all duration-200 text-lg">→</span>
    </a>

    <a href="https://www.linkedin.com/in/hooshmandrahmani" target="_blank" rel="noopener"
      class="group flex items-center gap-5 p-5 rounded-2xl border border-base-300 hover-green-border hover:bg-base-200 hover:shadow-md hover:-translate-y-[2px] transition-all duration-200">
      <div class="w-11 h-11 rounded-xl bg-base-200 group-hover:bg-base-300 group-hover:text-site-green flex items-center justify-center shrink-0 transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" class="opacity-70" style="fill: currentColor;">
          <circle cx="4.983" cy="5.009" r="2.188"></circle>
          <path d="M9.237 8.855v12.139h3.769v-6.003c0-1.584.298-3.118 2.262-3.118 1.937 0 1.961 1.811 1.961 3.218v5.904H21v-6.657c0-3.27-.704-5.783-4.526-5.783-1.835 0-3.065 1.007-3.568 1.96h-.051v-1.66H9.237zm-6.142 0H6.87v12.139H3.095z"></path>
        </svg>
      </div>
      <div class="grow">
        <div class="font-semibold">LinkedIn</div>
        <div class="text-sm opacity-50 mt-0.5">linkedin.com/in/hooshmandrahmani</div>
      </div>
      <span class="opacity-30 group-hover:opacity-70 group-hover:translate-x-1 transition-all duration-200 text-lg">→</span>
    </a>

    <a href="https://www.instagram.com/hooshmandr" target="_blank" rel="noopener"
      class="group flex items-center gap-5 p-5 rounded-2xl border border-base-300 hover-green-border hover:bg-base-200 hover:shadow-md hover:-translate-y-[2px] transition-all duration-200">
      <div class="w-11 h-11 rounded-xl bg-base-200 group-hover:bg-base-300 group-hover:text-site-green flex items-center justify-center shrink-0 transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" class="opacity-70" style="fill: currentColor;">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
        </svg>
      </div>
      <div class="grow">
        <div class="font-semibold">Instagram</div>
        <div class="text-sm opacity-50 mt-0.5">instagram.com/hooshmandr</div>
      </div>
      <span class="opacity-30 group-hover:opacity-70 group-hover:translate-x-1 transition-all duration-200 text-lg">→</span>
    </a>

  </div>
</BaseLayout>
