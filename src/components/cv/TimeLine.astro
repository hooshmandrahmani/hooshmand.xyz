---
const { title, institution, date, location } = Astro.props;
---

<div class="group flex gap-4">
  <!-- Dot + connecting line -->
  <div class="flex flex-col items-center shrink-0 pt-[5px]">
    <span class="w-2.5 h-2.5 rounded-full bg-base-content/60 group-hover:bg-site-green transition-colors duration-200 shrink-0"></span>
    <span class="timeline-line w-px bg-base-content/15 group-hover:bg-site-green group-hover:opacity-50 transition-colors duration-200 flex-1 mt-1.5"></span>
  </div>
  <!-- Content -->
  <div class="timeline-content pb-7 grow min-w-0">
    <div class="flex items-start justify-between gap-4">
      <h3 class="font-bold text-base leading-snug">{title}</h3>
      {date && <span class="text-sm opacity-50 text-right shrink-0 whitespace-nowrap mt-0.5">{date}</span>}
    </div>
    {(institution || location) && (
      <div class="flex items-start justify-between gap-4 mt-0.5">
        {institution && <span class="text-sm opacity-60">{institution}</span>}
        {location && <span class="text-sm opacity-45 text-right shrink-0 whitespace-nowrap">{location}</span>}
      </div>
    )}
    <div class="mt-3 text-sm leading-relaxed">
      <slot />
    </div>
  </div>
</div>
