---
const { title, subtitle } = Astro.props;
---

<div class="pl-4 border-l-2 border-base-300 hover:border-[#3DAA72] transition-colors duration-200">
  <h3 class="font-semibold leading-snug">{title}</h3>
  <p class="text-sm opacity-55 mt-0.5 mb-2">{subtitle}</p>
  <div class="text-sm leading-relaxed opacity-85">
    <slot />
  </div>
</div>
