---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "font-bold";
---

<ul class="menu grow shrink menu-md overflow-y-auto">
  <li>
    <a class="py-3 text-base flex items-center gap-3" id="home" href="/">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      Home
    </a>
  </li>
  <li>
    <a class="py-3 text-base flex items-center gap-3" id="projects" href="/projects">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70">
        <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
        <polyline points="2 17 12 22 22 17"></polyline>
        <polyline points="2 12 12 17 22 12"></polyline>
      </svg>
      Projects
    </a>
    <ul class="ml-2 mt-0">
      <li>
        <a class="py-1.5 text-sm opacity-70 hover:opacity-100 flex items-center gap-1.5 focus:bg-transparent active:bg-transparent" id="projects-optimization" href="/projects/#optimization-uncertainty">
          <span class="opacity-50">→</span> Optimization & Uncertainty
        </a>
      </li>
      <li>
        <a class="py-1.5 text-sm opacity-70 hover:opacity-100 flex items-center gap-1.5 focus:bg-transparent active:bg-transparent" id="projects-ml" href="/projects/#machine-learning">
          <span class="opacity-50">→</span> Machine Learning
        </a>
      </li>
      <li>
        <a class="py-1.5 text-sm opacity-70 hover:opacity-100 flex items-center gap-1.5 focus:bg-transparent active:bg-transparent" id="projects-empirical" href="/projects/#empirical-research">
          <span class="opacity-50">→</span> Empirical Research
        </a>
      </li>
    </ul>
  </li>
  <li>
    <a class="py-3 text-base flex items-center gap-3" id="cv" href="/cv">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
      </svg>
      CV
    </a>
  </li>
  <li>
    <a class="py-3 text-base flex items-center gap-3" id="contact" href="/contact">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70">
        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
        <path d="M3 7l9 6 9-6"></path>
      </svg>
      Contact
    </a>
  </li>
</ul>

<script define:vars={{ sideBarActiveItemID }}>
  function clearSubLinks() {
    document.querySelectorAll('a[href^="/projects/#"]').forEach((el) => {
      el.classList.remove("font-bold", "opacity-100");
      el.classList.add("opacity-70");
    });
  }

  function activateSubLink(hash) {
    if (!hash) return;
    const subLink = document.querySelector(`a[href="/projects/${hash}"]`);
    if (subLink) {
      clearSubLinks();
      subLink.classList.add("font-bold", "opacity-100");
      subLink.classList.remove("opacity-70");
    }
  }

  document.addEventListener("astro:page-load", () => {
    // Clear all previous active states
    ["home", "projects", "cv", "contact"].forEach((id) => {
      document.getElementById(id)?.classList.remove("font-bold");
    });
    clearSubLinks();

    // Bold the active main nav item
    document.getElementById(sideBarActiveItemID)?.classList.add("font-bold");

    // Bold the matching sub-link based on current hash
    activateSubLink(window.location.hash);

    // On sub-link click: bold immediately (works on same-page scroll too)
    document.querySelectorAll('a[href^="/projects/#"]').forEach((el) => {
      el.addEventListener("click", () => {
        const hash = el.getAttribute("href").split("#")[1];
        activateSubLink("#" + hash);
      });
    });
  });
</script>
