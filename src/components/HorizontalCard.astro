---
const { title, titlePrefix, img, desc, url, badge, tags, target = "_blank" } = Astro.props;
import { Image } from "astro:assets";
const tag_url = url.split("/").slice(0, -1).join("/") + "/tag";
---

<div class="rounded-xl border border-base-300 hover-green-border hover:shadow-md hover:-translate-y-[2px] transition-all duration-200 ease-out">
  <a href={url} target={target}>
    <div class="hero-content flex-col md:flex-row gap-5 p-5">
      {
        img && (
          <Image
            src={img}
            width={750}
            height={422}
            format="webp"
            alt={title}
            class="max-w-full md:max-w-[12rem] rounded-lg object-cover"
          />
        )
      }
      <div class="grow w-full">
        <h1 class="text-lg font-semibold leading-snug">
          {titlePrefix && <span class="text-[#2E7D55]">{titlePrefix} — </span>}{title}{badge && <span class="badge badge-secondary text-xs ml-2 align-middle">{badge}</span>}
        </h1>
        <p class="mt-2 text-sm opacity-70 leading-relaxed">{desc}</p>
        <div class="flex items-center justify-between mt-3 flex-wrap gap-2">
          <span class="flex items-center gap-2 text-sm font-medium opacity-60 hover:opacity-100 transition-opacity duration-150">
            Read more about the project →
          </span>
          {tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 justify-end">
              {tags.map((tag) => (
                <a
                  href={`${tag_url}/${tag}`}
                  class="text-xs px-2.5 py-0.5 rounded-full border border-base-300 opacity-70 hover:opacity-100 transition-all duration-150"
                >
                  {tag}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </a>
</div>
